DAYTONA_API_KEY=your_daytona_api_key
DAYTONA_SNAPSHOT=your_openclaw_snapshot_name
OPENCLAW_AUTH_TOKEN=your_openclaw_gateway_token

# Kafka chat transport (RUH-410)
# When enabled, chat requests/responses use Kafka instead of Redis Streams.
# Requires KAFKA_BOOTSTRAP_SERVERS to be set.
USE_KAFKA_FOR_CHAT=false
KAFKA_BOOTSTRAP_SERVERS=
KAFKA_AGENT_CHAT_TOPIC=agent_chat_requests
KAFKA_AGENT_RESPONSE_TOPIC=agent_chat_responses
